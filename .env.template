MLFLOW_TRACKING="True"
MLFLOW_TRACKING_URI="http://127.0.0.1:5000"

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_ENDPOINT=your_endpoint_url
AWS_S3_BUCKET=your_bucket_name
AWS_DEFAULT_REGION=your_default_region

ANTHROPIC_VERSION="bedrock_api_version"
ANTHROPIC_MODEL_ID="your_model_id"
ANTHROPIC_MODEL_REGION="anthropic_region"

# BERT model locations for the lithology classification endpoint.
# BERT_LOCAL: true = load from local paths | false = download from S3 on first request
# BERT_SPLIT: true = shared backbone + task-specific heads | false = single full model per task
BERT_LOCAL=false
BERT_SPLIT=false

# local + full  (BERT_LOCAL=true,  BERT_SPLIT=false):
BERT_MODEL_PATH_LITHOLOGY=/path/to/lithology_models/best_model_lithology
BERT_MODEL_PATH_EN_MAIN=/path/to/en_models/best_model

# local + split (BERT_LOCAL=true,  BERT_SPLIT=true):
BERT_MODEL_PATH_BACKBONE=/path/to/backbone/backbone.safetensors
BERT_MODEL_PATH_LITHOLOGY_HEAD=/path/to/lithology_head
BERT_MODEL_PATH_EN_MAIN_HEAD=/path/to/en_main_head

# s3    + full  (BERT_LOCAL=false, BERT_SPLIT=false):
BERT_MODEL_S3_BUCKET=your_model_bucket_name
BERT_MODEL_S3_KEY_LITHOLOGY=lithology_models/best_model_lithology
BERT_MODEL_S3_KEY_USCS=uscs_models/best_model_class_balancing
BERT_MODEL_S3_KEY_EN_MAIN=en_models/best_model

# s3    + split (BERT_LOCAL=false, BERT_SPLIT=true) — uses the same BERT_MODEL_S3_BUCKET:
BERT_MODEL_S3_KEY_BACKBONE=backbone
BERT_MODEL_S3_KEY_LITHOLOGY_HEAD=lithology_head
BERT_MODEL_S3_KEY_EN_MAIN_HEAD=en_main_head